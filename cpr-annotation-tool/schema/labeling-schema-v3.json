{
  "schema_version": "labeling-v3",
  "rubric_version": "rubric-v2",
  "rubric_ref": "../../cpr-eval/schema/rubric-v2.json",
  "supersedes": "labeling-v2",

  "design_principles": [
    "1. 平台目标 = 为 vea 建可复现数据集（不是文件夹也不是仪表盘）",
    "2. 三段闭环：收集 ingest / 整理 curate / 展示 serve",
    "3. v2 的 5 类 contribution envelope 保留",
    "4. 新增三层抽象：dataset（容器） / snapshot（不可变版本） / relationship（关系图）",
    "5. snapshot 是 vea 唯一稳定引用对象，dataset 可变，contribution 可演进"
  ],

  "top_level_collections": {
    "contributions/{contribution_id}.json":  "5 种 kind 共用的 envelope（继承 v2）",
    "datasets/{dataset_id}.json":            "dataset 元数据 + 当前包含的 contribution_ids（可变）",
    "snapshots/{snapshot_id}.json":          "dataset 的不可变快照（vea 引用对象）",
    "relationships/{relationship_id}.json":  "贡献间关系（derives_from / supersedes / compares_against / cites）",
    "rubric_proposals/{proposal_id}.json":   "rubric_note 类型的延伸记录",
    "audit_log/{date}.jsonl":                "所有写操作的审计日志",
    "users/{user_id}.json":                  "标注者 / reviewer / curator 账号"
  },

  "contribution_envelope": {
    "_inherits_from": "labeling-v2 contribution_envelope",
    "_changes": [
      "+ dataset_ids: 该 contribution 属于哪些 dataset（一个贡献可属多个 dataset）",
      "+ relationship_ids: 该 contribution 出现在哪些 relationship 里",
      "+ revocation: 知情同意撤回信息"
    ],

    "dataset_ids":      { "type": "array<string>", "required": true, "min_length": 1, "note": "至少属于 1 个 dataset" },
    "relationship_ids": { "type": "array<string>", "required": false },
    "revocation": {
      "type": "object|null", "required": false,
      "fields": {
        "revoked_at": "datetime",
        "revoked_by": "string (user_id)",
        "reason":     "string",
        "scope":      { "enum": ["full", "media_only", "metadata_only"] },
        "affects_snapshots": "array<snapshot_id>"
      },
      "note": "撤回不删除 contribution 本身，但 export 时按 scope 过滤"
    }
  },

  "dataset": {
    "purpose": "一组 contribution 的逻辑容器（cohort / 主题）。可变。",
    "fields": {
      "dataset_id":     { "type": "string", "required": true, "example": "cpr-cohort-2026-06" },
      "name":           { "type": "string", "required": true },
      "description":    { "type": "string", "required": true },
      "intended_use":   { "type": "array<string>", "required": true, "example": ["vea-training", "vea-eval"] },
      "tags":           { "type": "array<string>", "required": false },
      "contribution_ids": { "type": "array<string>", "required": true, "note": "可增删" },
      "created_by":     { "type": "string", "required": true },
      "created_at":     { "type": "datetime", "required": true },
      "updated_at":     { "type": "datetime", "required": true },
      "default_license_filter": {
        "type": "string", "required": true,
        "enum": ["all", "exclude_team_only", "research_and_public_only", "public_only"],
        "default": "exclude_team_only"
      },
      "thresholds": {
        "type": "object", "required": false,
        "note": "覆盖率告警阈值",
        "fields": {
          "min_ref_negative_per_error": { "type": "integer", "default": 3 },
          "min_ref_positive_per_step":  { "type": "integer", "default": 2 },
          "min_comparison_per_error":   { "type": "integer", "default": 1 }
        }
      }
    }
  },

  "snapshot": {
    "purpose": "dataset 的不可变版本。vea 唯一引用对象。",
    "fields": {
      "snapshot_id":     { "type": "string", "required": true, "example": "cpr-cohort-2026-06@v3" },
      "dataset_id":      { "type": "string", "required": true },
      "version_label":   { "type": "string", "required": true, "example": "v3" },
      "created_at":      { "type": "datetime", "required": true },
      "created_by":      { "type": "string", "required": true },
      "description":     { "type": "string", "required": true },
      "intended_use":    { "type": "array<string>", "required": true },

      "rubric_version":  { "type": "string", "required": true, "note": "锚定的 rubric 版本，永不可改" },
      "schema_version":  { "type": "string", "required": true, "note": "本 schema 版本" },

      "contribution_ids":  { "type": "array<string>", "required": true, "note": "冻结快照时的 contribution 列表" },
      "media_checksums":   { "type": "object<media_id, sha256>", "required": true, "note": "媒体完整性校验" },
      "content_hash":      { "type": "string", "required": true, "note": "整个 snapshot 的内容哈希，vea 加载时校验" },

      "splits": {
        "type": "object", "required": true,
        "fields": {
          "train":  "array<contribution_id>",
          "val":    "array<contribution_id>",
          "test":   "array<contribution_id>",
          "inter_rater_subset": "array<contribution_id>"
        },
        "note": "split 必须互斥且并集 = contribution_ids"
      },

      "stats": {
        "type": "object", "required": true,
        "fields": {
          "by_kind":           "object<kind, integer>",
          "by_step_coverage":  "object<step_id, {graded, ref_pos, ref_neg, comparison}>",
          "by_error_coverage": "object<error_code, {ref_neg, comparison}>",
          "gaps":              "array<{target, kind, current, threshold}>"
        }
      },

      "audit": {
        "signed_by": "string",
        "signature": "string (ed25519 推荐)"
      },

      "status": { "type": "string", "enum": ["draft", "published", "deprecated"], "default": "draft" }
    },
    "immutability_rules": [
      "1. status=published 后 contribution_ids / splits / content_hash / rubric_version 不可改",
      "2. 撤回引用的 contribution 不修改 snapshot，只在 export 时过滤",
      "3. 修订 snapshot 必须打新版本（v3 → v4），不允许覆盖"
    ]
  },

  "relationship": {
    "purpose": "贡献间的引用关系图",
    "fields": {
      "relationship_id": { "type": "string", "required": true },
      "from":            { "type": "string", "required": true, "note": "contribution_id" },
      "to":              { "type": "string", "required": true, "note": "contribution_id" },
      "type":            { "type": "string", "required": true, "enum": ["derives_from", "supersedes", "compares_against", "cites", "duplicates"] },
      "details": {
        "type": "object", "required": false,
        "examples": [
          { "extracted_interval": [12.3, 18.5] },
          { "supersede_reason": "evidence updated" },
          { "duplicate_confidence": 0.92 }
        ]
      },
      "created_by": "string",
      "created_at": "datetime"
    }
  },

  "user": {
    "purpose": "账号体系",
    "fields": {
      "user_id":          "string (脱敏稳定 ID)",
      "display_name":     "string",
      "roles":            { "type": "array<string>", "enum_items": ["producer", "reviewer", "curator", "consumer", "admin"] },
      "specialty":        "string (急诊 / 重症 / 教研)",
      "credential_level": "string",
      "institution":      "string",
      "active":           "boolean",
      "created_at":       "datetime"
    },
    "permissions": {
      "producer":  ["create_contribution", "edit_own_draft", "submit"],
      "reviewer":  ["producer", "review_assigned", "comment"],
      "curator":   ["reviewer", "create_dataset", "create_snapshot", "approve_rubric_proposal", "view_quality_dashboard"],
      "admin":     ["all", "manage_users", "delete_data"]
    }
  },

  "audit_log_entry": {
    "purpose": "所有写操作落地",
    "fields": {
      "ts":         "datetime",
      "actor":      "user_id",
      "action":     { "enum": ["create", "update", "submit", "approve", "reject", "supersede", "revoke", "snapshot", "export"] },
      "target_kind":"string",
      "target_id":  "string",
      "diff":       "object (changed fields before/after)",
      "request_id": "string"
    },
    "format": "JSONL，按日期切片：audit_log/2026-06-05.jsonl"
  },

  "validation_rules": [
    "1. contribution.dataset_ids 至少 1 项，且引用的 dataset 必须存在",
    "2. 所有 v2 的校验规则继承（step_links 必填、error_links 限定在 rubric 内、status 流转等）",
    "3. snapshot 的 splits 必须互斥且并集 = contribution_ids",
    "4. snapshot.content_hash 必须等于按确定性算法对 contribution_ids + media_checksums 求 sha256 的结果",
    "5. snapshot.status=published 后任何字段改动拒绝",
    "6. relationship.from / to 必须存在",
    "7. revocation.scope=full 后该 contribution 不能再进入新 snapshot",
    "8. dataset 删除前必须无 published snapshot 引用"
  ],

  "vea_export": {
    "_inherits_from": "labeling-v2 vea_export",
    "_extends": [
      "导出粒度从 contribution 级升到 snapshot 级",
      "新增 manifest 文件（snapshot 元数据 YAML）",
      "新增 by_step / by_error 切片视图",
      "导出时执行 revocation_check 并按 license_filter 过滤"
    ],
    "endpoints_ref": "../docs/vea-data-contract-v3.md"
  },

  "migration_from_v2": [
    "1. 现有 v2 contribution 自动归入 dataset_id='cpr-default-2026-06'",
    "2. 现有 contribution 无 relationship 记录，按需手工补",
    "3. 首个 snapshot 在 dataset 准备好后手动打：scripts/snapshot.py --dataset cpr-default-2026-06",
    "4. v2 没有 user 系统，迁移时按 author.annotator_id 创建占位 user 记录"
  ]
}
