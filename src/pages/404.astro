---
const baseUrl = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const personStructuredData = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  '@id': 'https://estelledc.github.io/#person',
  name: 'Jason Xun',
  url: 'https://estelledc.github.io/',
};
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="robots" content="noindex" />
    <meta name="theme-color" content="#faf6f0" />
    <title>页面未找到 | Jason's Study</title>
    <script type="application/ld+json" set:html={JSON.stringify(personStructuredData)}></script>
  </head>
  <body>
    <main>
      <p class="code">404</p>
      <h1>页面未找到</h1>
      <p class="summary">这个 Study 页面不存在，或者路径已经变化。</p>
      <nav aria-label="恢复导航">
        <a class="primary" href={`${baseUrl}start/`}>返回学习入口</a>
        <a href={`${baseUrl}projects-atlas/`}>查看项目地图</a>
      </nav>
    </main>
  </body>
</html>

<style>
  :global(*) {
    box-sizing: border-box;
  }

  :global(body) {
    min-height: 100vh;
    margin: 0;
    display: grid;
    place-items: center;
    padding: 2rem;
    color: #1a1a1a;
    background: #faf6f0;
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont,
      "Segoe UI", sans-serif;
  }

  main {
    width: min(36rem, 100%);
    padding-block: 3rem;
    border-block: 1px solid rgba(0, 0, 0, 0.12);
  }

  .code {
    margin: 0 0 1rem;
    color: #a83a26;
    font: 700 0.85rem/1.2 ui-monospace, SFMono-Regular, Menlo, monospace;
    letter-spacing: 0.16em;
  }

  h1 {
    margin: 0;
    font-family: Georgia, "Times New Roman", serif;
    font-size: clamp(2.4rem, 8vw, 4.8rem);
    line-height: 1;
    letter-spacing: -0.04em;
  }

  .summary {
    margin: 1.5rem 0 0;
    color: #5c554d;
    font-size: 1.05rem;
    line-height: 1.7;
  }

  nav {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 2rem;
  }

  a {
    display: inline-flex;
    min-height: 2.75rem;
    align-items: center;
    padding: 0.65rem 1rem;
    border: 1px solid rgba(0, 0, 0, 0.18);
    color: #1a1a1a;
    text-decoration: none;
  }

  a:hover,
  a:focus-visible {
    border-color: #a83a26;
    outline: 2px solid transparent;
    color: #a83a26;
  }

  a.primary {
    border-color: #a83a26;
    color: #faf6f0;
    background: #a83a26;
  }

  a.primary:hover,
  a.primary:focus-visible {
    color: #fff;
    background: #8f3020;
  }

  @media (prefers-color-scheme: dark) {
    :global(body) {
      color: #faf6f0;
      background: #1a1a1a;
    }

    main {
      border-color: rgba(250, 246, 240, 0.18);
    }

    .summary {
      color: #c9c1b7;
    }

    a {
      border-color: rgba(250, 246, 240, 0.24);
      color: #faf6f0;
    }
  }
</style>
