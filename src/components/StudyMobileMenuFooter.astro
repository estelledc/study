---
import LanguageSelect from 'virtual:starlight/components/LanguageSelect';
import SocialIcons from 'virtual:starlight/components/SocialIcons';
import ThemeSelect from 'virtual:starlight/components/ThemeSelect';
---

<nav class="study-mobile-links" aria-label="Jason 全局导航">
  <a class="jx-return-to-hub" href="https://estelledc.github.io/">Jason Hub</a>
  <a class="jx-pill" href="https://estelledc.github.io/about/">About</a>
  <a class="jx-pill" href="https://estelledc.github.io/resume/">Resume</a>
  <a class="jx-pill" href="https://github.com/estelledc/study">GitHub</a>
</nav>

<div class="mobile-preferences sl-flex">
  <div class="social-icons">
    <SocialIcons />
  </div>
  <ThemeSelect />
  <LanguageSelect />
</div>

<style>
  @layer starlight.core {
    .study-mobile-links {
      display: flex;
      flex-wrap: wrap;
      gap: 0.75rem;
      padding-block: 1rem;
      border-top: 1px solid var(--sl-color-gray-6);
    }

    .study-mobile-links .jx-return-to-hub {
      width: 100%;
    }

    .social-icons {
      display: flex;
      margin-inline-end: auto;
      gap: 1rem;
      align-items: center;
      padding-block: 1rem;
    }

    .social-icons:empty {
      display: none;
    }

    .mobile-preferences {
      justify-content: space-between;
      flex-wrap: wrap;
      border-top: 1px solid var(--sl-color-gray-6);
      column-gap: 1rem;
      padding: 0.5rem 0;
    }
  }
</style>
