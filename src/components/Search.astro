---
import DefaultSearch from '@astrojs/starlight/components/Search.astro';
---

<DefaultSearch {...Astro.props} />

<script>
  function installSearchStatusContract() {
    const host = document.querySelector('site-search');
    if (!(host instanceof HTMLElement) || host.dataset.studyA11yObserver === 'ready') return;

    const enhance = () => {
      const message = host.querySelector('.pagefind-ui__message');
      if (!(message instanceof HTMLElement)) return;
      message.setAttribute('role', 'status');
      message.setAttribute('aria-live', 'polite');
      message.setAttribute('aria-atomic', 'true');
    };

    host.dataset.studyA11yObserver = 'ready';
    enhance();
    new MutationObserver(enhance).observe(host, { childList: true, subtree: true });
  }

  document.addEventListener('DOMContentLoaded', installSearchStatusContract, { once: true });
  document.addEventListener('astro:page-load', installSearchStatusContract);
</script>
